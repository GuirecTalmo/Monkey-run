# Base de données PostgreSQL
# Copiez ce fichier en .env et adaptez les valeurs.
# Remplacez "password" par le mot de passe de l'utilisateur postgres (défini à l'installation).
# Port : 5432 par défaut, ou 5433 si PostgreSQL a été installé sur un autre port.
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=[schema]
DATABASE_URL="postgresql://postgres:monkeyrun123@localhost:5432/monkey_run?schema=public"

# JWT (authentification)
JWT_SECRET="changez-moi-en-production-32-caracteres-minimum"
JWT_EXPIRATION="7d"

# Application
NODE_ENV="development"
PORT=3000
